# PORT
PORT = 3000

# DB
DATABASE_URL="postgresql://user:passsword@host:5432/db_name"

# Environment
NODE_ENV=development

# TOKEN
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# LOG
LOG_FORMAT=dev
LOG_DIR=../logs

# CORS
# Single origin: ORIGIN = https://example.com
# Multiple origins (comma-separated): ORIGIN = https://example.com,https://app.example.com
# Allow all origins: ORIGIN = *
ORIGIN = *
CREDENTIALS = true

# Cookie Configuration
# Leave COOKIE_DOMAIN empty for default domain
# Set NODE_ENV to 'staging' or 'production' for secure cookies
COOKIE_AUTH_NAME = Authorization
COOKIE_REFRESH_NAME = RefreshToken
# COOKIE_DOMAIN =
# COOKIE_SECURE = true

# Object Storage (S3 compatible)
# For AWS S3: only S3_BUCKET and S3_REGION required
# For MinIO/Garage: set S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY
# S3_FORCE_PATH_STYLE=true required for MinIO and Garage
S3_REGION = us-east-1
S3_BUCKET = my-bucket
# S3_ENDPOINT = http://localhost:9000
# S3_ACCESS_KEY = minioadmin
# S3_SECRET_KEY = minioadmin
# S3_FORCE_PATH_STYLE = true
