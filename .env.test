NODE_ENV=test
PORT=3001
DATABASE_URL=postgresql://test:test@localhost:5432/test_db
SECRET_KEY=test-secret-key-at-least-32-chars-long-for-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
LOG_FORMAT=dev
LOG_DIR=./logs
ORIGIN=*
CREDENTIALS=false
COOKIE_AUTH_NAME=Authorization
COOKIE_REFRESH_NAME=RefreshToken
S3_BUCKET=test-bucket
S3_REGION=us-east-1